# ── Yandex Cloud ──────────────────────────────────────────────────

# Один YANDEX_API_KEY сервисного аккаунта, разные способы auth по API:

#

# ┌─────────────┬──────────────────┬────────────────────────────────────────────┐

# │ API         │ Роль             │ Аутентификация в MKG                       │

# ├─────────────┼──────────────────┼────────────────────────────────────────────┤

# │ LLM (GPT)   │ ai.languageModels│ OpenAI SDK: api_key + project=folder_id  │

# │ OCR Vision  │ ai.vision.user   │ Api-Key + x-folder-id                      │

# │ Embeddings  │ ai.languageModels│ Api-Key + x-folder-id                      │

# │ Translate   │ ai.translate.user│ НЕ используется в MKG                      │

# └─────────────┴──────────────────┴────────────────────────────────────────────┘

#

# Scope API-ключа OCR: yc.ai.vision.execute
# Scope LLM: yc.ai.languageModels.execute
# Роль SA на каталоге: ai.vision.user или ai.editor
# Docs: https://aistudio.yandex.ru/docs/ru/vision/api-ref/authentication.html

#

YANDEX_API_KEY=your-yandex-api-key

YANDEX_FOLDER_ID=your-yandex-folder-id

YANDEX_LLM_BASE_URL=https://ai.api.cloud.yandex.net/v1

YANDEX_OCR_URL=https://ocr.api.cloud.yandex.net/ocr/v1/recognizeText

# Модели (URI: gpt://<folder>/<name>, emb://<folder>/<name>)

YANDEX_MODEL_PRO=yandexgpt-5.1

YANDEX_MODEL_LITE=yandexgpt-5-lite

YANDEX_EMB_DOC=text-search-doc/latest

YANDEX_EMB_QUERY=text-search-query/latest



# ── Neo4j (локально в docker-compose) ────────────────────────────

NEO4J_URI=bolt://neo4j:7687

NEO4J_USER=neo4j

NEO4J_PASSWORD=changeme

NEO4J_DATABASE=neo4j



# ── Qdrant ───────────────────────────────────────────────────────

QDRANT_URL=http://qdrant:6333

QDRANT_API_KEY=

QDRANT_COLLECTION_CHUNKS=mkg_chunks

QDRANT_COLLECTION_CLAIMS=mkg_claims

QDRANT_VECTOR_SIZE=256



# ── Postgres ─────────────────────────────────────────────────────

POSTGRES_HOST=postgres

POSTGRES_PORT=5432

POSTGRES_DB=mkg

POSTGRES_USER=mkg

POSTGRES_PASSWORD=changeme

DATABASE_URL=postgresql+asyncpg://mkg:changeme@postgres:5432/mkg



# ── Redis (брокер очереди) ───────────────────────────────────────

REDIS_URL=redis://redis:6379/0



# ── App ──────────────────────────────────────────────────────────

APP_ENV=dev

LOG_LEVEL=INFO

STORAGE_DIR=./data/storage

PROMPTS_PATH=./packages/prompts/catalog

DEFAULT_LLM_MODEL=yandexgpt

MAX_UPLOAD_BYTES=52428800

# AUTO_EXTRACT_AFTER_INGEST=true

